{
    "name": "eslint-config-zoro",
    "version": "9.1.2",
    "description": "A fully customized ESLint configuration based on the default ESLint, React and TypeScript rules.",
    "packageManager": "pnpm@10.33.0",
    "license": "MIT",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "author": {
        "name": "nonoroazoro",
        "email": "xiaochao.k@gmail.com"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/nonoroazoro/eslint-config-zoro"
    },
    "keywords": [
        "config",
        "eslint",
        "eslintconfig",
        "node",
        "perfectionist",
        "react",
        "stylistic",
        "typescript"
    ],
    "scripts": {
        "prepare": "lefthook install",
        "prebuild": "npm run test && rimraf dist",
        "prepublish": "npm run build",
        "build": "tsc && tsc-alias && npm run lint",
        "lint": "eslint src/**",
        "test": "vitest run",
        "upgradepackages": "ncu -u"
    },
    "engines": {
        "node": ">=18.18.0"
    },
    "dependencies": {
        "@stylistic/eslint-plugin": "^5.10.0",
        "eslint-plugin-perfectionist": "^5.7.0",
        "globals": "^17.4.0"
    },
    "devDependencies": {
        "@types/node": "^25.5.0",
        "@typescript-eslint/eslint-plugin": "^8.58.0",
        "@typescript-eslint/parser": "^8.58.0",
        "dprint": "^0.53.1",
        "eslint": "^9.39.4",
        "eslint-plugin-n": "^17.24.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "lefthook": "^2.1.4",
        "npm-check-updates": "^20.0.0",
        "rimraf": "^6.1.3",
        "tsc-alias": "^1.8.16",
        "typescript": "^6.0.2",
        "vitest": "^4.1.2"
    },
    "peerDependencies": {
        "@typescript-eslint/eslint-plugin": ">=8.58.0",
        "@typescript-eslint/parser": ">=8.58.0",
        "eslint": ">=9.39.0",
        "eslint-plugin-n": ">=17.24.0",
        "eslint-plugin-react": ">=7.37.0",
        "eslint-plugin-react-hooks": ">=7.0.0"
    },
    "peerDependenciesMeta": {
        "@typescript-eslint/eslint-plugin": {
            "optional": true
        },
        "@typescript-eslint/parser": {
            "optional": true
        },
        "eslint-plugin-n": {
            "optional": true
        },
        "eslint-plugin-react": {
            "optional": true
        },
        "eslint-plugin-react-hooks": {
            "optional": true
        }
    },
    "files": [
        "dist"
    ]
}
